{
  "manifest_version": 3,
  "name": "TikTok Creator Suite",
  "version": "3.0.0",
  "description": "สร้าง Script รีวิว + ปักตระกร้า TikTok อัตโนมัติในที่เดียว",
  "action": {
    "default_title": "TikTok Creator Suite"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "*://*.tiktok.com/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
